# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fullstack
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-please
JWT_EXPIRATION=24h
JWT_ISSUER=fullstack-go

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
UPLOAD_ALLOW_EXT=.jpg,.jpeg,.png,.gif,.webp,.pdf
